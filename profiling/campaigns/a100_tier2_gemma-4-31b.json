{
  "hardware": "A100",
  "gpus_per_node": 8,
  "model": "google/gemma-4-31B-it",
  "campaign_type": "tier2",
  "container": "vllm-openai-gemma4.sandbox",
  "_note": "A100 Tier-2 calibration on ramr at tp=2 (31B bf16 ~62GB is KV-starved at tp=1 for the N=256 decode staircase; tp=2 gives ~40GB/GPU KV). Gemma-4 needs the newer vLLM container.",
  "server": {
    "tp": 2,
    "max_num_seqs": 256,
    "max_num_batched_tokens": 8192,
    "enable_chunked_prefill": true,
    "enable_prefix_caching": false,
    "kv_cache_dtype": "auto",
    "max_model_len": 131072
  },
  "probes": ["decode_staircase", "prefill_staircase"]
}
